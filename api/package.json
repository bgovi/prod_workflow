{
  "name": "login_server",
  "version": "1.0.0",
  "description": "handles api calls for login/logout and api token",
  "main": "index.js",
  "engines": {
    "node": ">=20.11.1",
    "npm": ">=10.2.4"
  },
  "_moduleAliases": {
    "@src": "src"
  },
  "jest": {
    "moduleNameMapper": {
      "^@src/(.*)$": "<rootDir>/src/$1"
    }
